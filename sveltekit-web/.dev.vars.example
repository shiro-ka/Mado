# Copy to .dev.vars and fill in values for local development
# Never commit .dev.vars — it contains secrets

# Cloudflare-bound env vars (secrets only; KV/D1 bindings come from wrangler.toml)

# ES256 JWK keyset for OAuth DPoP signing — JSON array of JWK objects
# Generate a new key: npx @atproto/oauth-client-node generate-key ES256
OAUTH_PRIVATE_KEYS=[]

# Base URL of this app (used for OAuth redirect URIs and cookie secure flag)
# Use https://mado.blue for prod; http://localhost:8788 for wrangler dev
APP_URL=http://localhost:8788

# Secret token that gates /api/cron/check-sessions
CRON_SECRET=dev-secret
