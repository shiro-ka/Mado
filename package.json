{
  "name": "mado-sveltekit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node -e \"require('fs').copyFileSync('node_modules/@resvg/resvg-wasm/index_bg.wasm','static/resvg.wasm')\" && vite build",
