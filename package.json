    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.0",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.83.0"
  },
