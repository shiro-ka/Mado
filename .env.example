# App URL (used for OAuth client_id and redirect_uri)
NEXT_PUBLIC_APP_URL=https://mado.blue

# ATProtocol OAuth private keys (JSON array of JWK objects)
# Generate with: node -e "const{JoseKey}=require('@atproto/jwk-jose');JoseKey.generate(['ES256'],'mado-key-1').then(k=>console.log(JSON.stringify([k.privateJwk])))"
OAUTH_PRIVATE_KEYS=

# Upstash Redis (via Vercel Storage or direct Upstash console)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job authentication secret (openssl rand -hex 32)
CRON_SECRET=
